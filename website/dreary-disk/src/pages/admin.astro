---
export const prerender = false;

const WORKER_URL = "https://tg-cms-api.morentoofficial.workers.dev";
const SITE_NAME = "مجله هنری ماهون";
const LOGO_URL = "/sources/mahoon-logo.jpg";
---

<html lang="fa" dir="rtl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex, nofollow" />
    <title>پنل مدیریت حرفه‌ای | {SITE_NAME}</title>

    <style>
      @font-face {
        font-family: "MahoonFont";
        src: url("/fonts/mahoon-font.woff2") format("woff2");
        font-weight: 100 900;
        font-style: normal;
        font-display: swap;
      }

      :root {
        --bg: #f3efe7;
        --surface: #ffffff;
        --ink: #1b1712;
        --muted: #776b5f;
        --line: rgba(40, 32, 24, 0.12);
        --gold: #b88746;
        --gold-soft: #efe0c8;
        --dark: #15110d;
        --danger: #b84242;
        --green: #2f855a;
        --blue: #2b6cb0;
        --shadow: 0 24px 70px rgba(34, 24, 15, 0.12);
        --radius-xl: 32px;
        --radius-lg: 24px;
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        font-family: "MahoonFont", Tahoma, Arial, sans-serif;
        background:
          radial-gradient(circle at top right, rgba(184, 135, 70, 0.18), transparent 32%),
          linear-gradient(180deg, #fffaf1 0%, var(--bg) 100%);
        color: var(--ink);
      }

      button, input, textarea, select {
        font-family: inherit;
      }

      .container {
        width: min(1420px, calc(100% - 32px));
        margin: 0 auto;
      }

      .topbar {
        position: sticky;
        top: 0;
        z-index: 50;
        border-bottom: 1px solid var(--line);
        background: rgba(255, 250, 241, 0.9);
        backdrop-filter: blur(18px);
      }

      .topbar-inner {
        min-height: 86px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
      }

      .brand {
        display: flex;
        align-items: center;
        gap: 14px;
      }

      .brand img {
        width: 58px;
        height: 58px;
        object-fit: contain;
        background: #fff;
        padding: 7px;
        border-radius: 18px;
        border: 1px solid var(--line);
        box-shadow: 0 12px 32px rgba(34, 24, 15, 0.12);
      }

      .brand strong {
        display: block;
        font-size: 19px;
      }

      .brand span {
        display: block;
        margin-top: 5px;
        color: var(--muted);
        font-size: 13px;
      }

      .actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
      }

      .btn {
        border: 0;
        cursor: pointer;
        border-radius: 999px;
        padding: 12px 17px;
        font-size: 14px;
        transition: 0.2s ease;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        white-space: nowrap;
      }

      .btn:hover {
        transform: translateY(-2px);
      }

      .btn-primary {
        background: var(--dark);
        color: #fff;
      }

      .btn-gold {
        background: var(--gold-soft);
        color: #7a4d20;
      }

      .btn-danger {
        background: rgba(184, 66, 66, 0.12);
        color: var(--danger);
      }

      .btn-green {
        background: rgba(47, 133, 90, 0.12);
        color: var(--green);
      }

      .btn-blue {
        background: rgba(43, 108, 176, 0.12);
        color: var(--blue);
      }

      .btn-line {
        background: #fff;
        color: var(--ink);
        border: 1px solid var(--line);
      }

      .page {
        padding: 32px 0 72px;
      }

      .login-wrap {
        min-height: calc(100vh - 120px);
        display: grid;
        place-items: center;
      }

      .login-card {
        width: min(540px, 100%);
        background: rgba(255, 255, 255, 0.95);
        border: 1px solid var(--line);
        border-radius: var(--radius-xl);
        padding: 36px;
        box-shadow: var(--shadow);
      }

      .login-card h1 {
        margin: 18px 0 10px;
        font-size: 32px;
      }

      .login-card p {
        margin: 0 0 24px;
        color: var(--muted);
        line-height: 2;
      }

      .dashboard {
        display: none;
      }

      .dashboard.active,
      .login-wrap.active {
        display: block;
      }

      .login-wrap:not(.active) {
        display: none;
      }

      .field {
        display: grid;
        gap: 8px;
        margin-bottom: 16px;
      }

      .field label {
        color: var(--muted);
        font-size: 13px;
      }

      .input,
      .textarea,
      .select {
        width: 100%;
        border: 1px solid var(--line);
        border-radius: 18px;
        background: #fff;
        color: var(--ink);
        outline: 0;
        padding: 14px 15px;
        font-size: 15px;
      }

      .input:focus,
      .textarea:focus,
      .select:focus {
        border-color: rgba(184, 135, 70, 0.7);
        box-shadow: 0 0 0 4px rgba(184, 135, 70, 0.12);
      }

      .textarea {
        min-height: 280px;
        resize: vertical;
        line-height: 2;
        direction: rtl;
      }

      .textarea.small {
        min-height: 95px;
      }

      .stats {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 14px;
        margin-bottom: 20px;
      }

      .stat-card {
        background: rgba(255, 255, 255, 0.95);
        border: 1px solid var(--line);
        border-radius: var(--radius-lg);
        padding: 20px;
        box-shadow: 0 16px 42px rgba(34, 24, 15, 0.08);
      }

      .stat-card strong {
        display: block;
        font-size: 28px;
        color: var(--dark);
      }

      .stat-card span {
        display: block;
        margin-top: 6px;
        color: var(--muted);
        font-size: 13px;
      }

      .admin-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 520px;
        gap: 18px;
        align-items: start;
      }

      .panel {
        background: rgba(255, 255, 255, 0.95);
        border: 1px solid var(--line);
        border-radius: 30px;
        box-shadow: var(--shadow);
        overflow: hidden;
      }

      .panel-head {
        padding: 20px 22px;
        border-bottom: 1px solid var(--line);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
      }

      .panel-head h2 {
        margin: 0;
        font-size: 22px;
      }

      .panel-body {
        padding: 20px 22px;
      }

      .filters {
        display: grid;
        grid-template-columns: 1fr 160px 160px 160px;
        gap: 10px;
        margin-bottom: 14px;
      }

      .bulkbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        padding: 12px;
        background: rgba(184, 135, 70, 0.09);
        border: 1px solid rgba(184, 135, 70, 0.18);
        border-radius: 20px;
        margin-bottom: 14px;
      }

      .bulkbar strong {
        color: var(--dark);
        font-size: 14px;
      }

      .posts-list {
        display: grid;
        gap: 12px;
        max-height: 830px;
        overflow: auto;
        padding-left: 6px;
      }

      .post-row {
        border: 1px solid var(--line);
        background: #fff;
        border-radius: 22px;
        padding: 14px;
        display: grid;
        grid-template-columns: 26px 86px 1fr;
        gap: 14px;
        cursor: pointer;
        transition: 0.2s ease;
      }

      .post-row:hover,
      .post-row.active {
        border-color: rgba(184, 135, 70, 0.65);
        box-shadow: 0 12px 28px rgba(34, 24, 15, 0.08);
      }

      .post-check {
        display: flex;
        align-items: center;
        justify-content: center;
      }

      .post-check input {
        width: 18px;
        height: 18px;
      }

      .thumb {
        width: 86px;
        height: 86px;
        border-radius: 18px;
        background: #efe4d4;
        overflow: hidden;
        display: grid;
        place-items: center;
        color: var(--muted);
        font-size: 12px;
        text-align: center;
        padding: 8px;
      }

      .thumb img,
      .thumb video {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      .post-row h3 {
        margin: 0 0 8px;
        font-size: 17px;
        line-height: 1.7;
      }

      .post-row p {
        margin: 0;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.8;
      }

      .row-meta {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 10px;
      }

      .badge {
        display: inline-flex;
        align-items: center;
        width: fit-content;
        border-radius: 999px;
        padding: 7px 10px;
        font-size: 12px;
        background: var(--gold-soft);
        color: #7a4d20;
      }

      .badge.green {
        background: rgba(47, 133, 90, 0.12);
        color: var(--green);
      }

      .badge.gray {
        background: rgba(119, 107, 95, 0.12);
        color: var(--muted);
      }

      .badge.red {
        background: rgba(184, 66, 66, 0.12);
        color: var(--danger);
      }

      .badge.blue {
        background: rgba(43, 108, 176, 0.12);
        color: var(--blue);
      }

      .editor-actions {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-top: 16px;
      }

      .switch-line {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 13px 14px;
        background: #fff;
        margin-bottom: 16px;
      }

      .switch-line span {
        color: var(--muted);
        font-size: 14px;
      }

      .switch-line input {
        width: 18px;
        height: 18px;
      }

      .message {
        display: none;
        margin-bottom: 16px;
        border-radius: 18px;
        padding: 13px 14px;
        font-size: 14px;
        line-height: 1.8;
      }

      .message.show {
        display: block;
      }

      .message.ok {
        background: rgba(47, 133, 90, 0.12);
        color: var(--green);
      }

      .message.error {
        background: rgba(184, 66, 66, 0.12);
        color: var(--danger);
      }

      .empty {
        padding: 30px;
        text-align: center;
        color: var(--muted);
        border: 1px dashed var(--line);
        border-radius: 22px;
      }

      .editor-meta {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 8px;
        margin-bottom: 16px;
      }

      .mini-stat {
        background: #fff;
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 12px;
      }

      .mini-stat strong {
        display: block;
        font-size: 18px;
      }

      .mini-stat span {
        color: var(--muted);
        font-size: 12px;
      }

      .media-uploader {
        border: 1px solid var(--line);
        border-radius: 24px;
        padding: 16px;
        background: #fff;
        margin-bottom: 18px;
      }

      .media-uploader-row {
        display: grid;
        grid-template-columns: 1fr auto auto;
        gap: 8px;
        align-items: center;
      }

      .media-preview {
        margin-top: 14px;
        border-radius: 20px;
        background: #f7f0e6;
        border: 1px solid var(--line);
        overflow: hidden;
        min-height: 92px;
        display: grid;
        place-items: center;
        color: var(--muted);
        text-align: center;
        padding: 14px;
      }

      .media-preview img,
      .media-preview video {
        width: 100%;
        max-height: 280px;
        object-fit: contain;
        display: block;
        border-radius: 16px;
      }

      .media-preview audio {
        width: 100%;
      }

      .media-preview .file-preview {
        display: grid;
        gap: 8px;
      }

      .preview {
        margin-top: 18px;
        border: 1px solid var(--line);
        border-radius: 24px;
        overflow: hidden;
        background: #fffaf1;
      }

      .preview-head {
        padding: 16px;
        border-bottom: 1px solid var(--line);
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
      }

      .preview-body {
        padding: 18px;
      }

      .preview-title {
        margin: 0 0 12px;
        font-size: 22px;
        line-height: 1.7;
        color: var(--dark);
      }

      .preview-content {
        white-space: pre-wrap;
        color: #2b231b;
        line-height: 2.1;
        font-size: 15px;
      }

      .preview-tags {
        display: flex;
        gap: 8px;
        flex-wrap: wrap;
        margin-top: 16px;
      }

      .tab-title {
        margin: 24px 0 12px;
        font-size: 16px;
        color: var(--dark);
      }

      @media (max-width: 1150px) {
        .admin-grid {
          grid-template-columns: 1fr;
        }

        .stats {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .filters {
          grid-template-columns: 1fr 1fr;
        }
      }

      @media (max-width: 680px) {
        .topbar-inner {
          flex-direction: column;
          align-items: flex-start;
          padding: 14px 0;
        }

        .actions {
          width: 100%;
        }

        .btn {
          flex: 1;
        }

        .stats {
          grid-template-columns: 1fr;
        }

        .filters {
          grid-template-columns: 1fr;
        }

        .bulkbar {
          align-items: flex-start;
          flex-direction: column;
        }

        .post-row {
          grid-template-columns: 28px 1fr;
        }

        .thumb {
          grid-column: 1 / -1;
          width: 100%;
          height: 190px;
        }

        .editor-meta {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .media-uploader-row {
          grid-template-columns: 1fr;
        }

        .login-card {
          padding: 26px;
          border-radius: 26px;
        }
      }
    </style>
  </head>

  <body>
    <header class="topbar">
      <div class="container topbar-inner">
        <div class="brand">
          <img src={LOGO_URL} alt="لوگوی ماهون" />
          <div>
            <strong>پنل مدیریت حرفه‌ای ماهون</strong>
            <span>مدیریت محتوا، فایل، SEO، انتشار و آرشیو</span>
          </div>
        </div>

        <div class="actions">
          <a class="btn btn-line" href="/">مشاهده سایت</a>
          <button class="btn btn-blue" id="exportBtn" type="button">خروجی JSON</button>
          <button class="btn btn-danger" id="logoutBtn" type="button">خروج</button>
        </div>
      </div>
    </header>

    <main class="page">
      <div class="container">
        <section class="login-wrap" id="loginView">
          <div class="login-card">
            <span class="badge">ورود مدیر</span>
            <h1>ورود به پنل مدیریت</h1>
            <p>رمز مدیریت همان Secret با نام ADMIN_TOKEN در Cloudflare Worker است.</p>

            <div class="message" id="loginMessage"></div>

            <div class="field">
              <label for="tokenInput">رمز مدیریت</label>
              <input class="input" id="tokenInput" type="password" placeholder="ADMIN_TOKEN را وارد کن" />
            </div>

            <button class="btn btn-primary" id="loginBtn" type="button">ورود به پنل</button>
          </div>
        </section>

        <section class="dashboard" id="dashboardView">
          <div class="stats">
            <div class="stat-card"><strong id="totalCount">0</strong><span>کل پست‌ها</span></div>
            <div class="stat-card"><strong id="publishedCount">0</strong><span>منتشر شده</span></div>
            <div class="stat-card"><strong id="draftCount">0</strong><span>منتشر نشده</span></div>
            <div class="stat-card"><strong id="mediaCount">0</strong><span>دارای فایل</span></div>
            <div class="stat-card"><strong id="viewsCount">0</strong><span>مجموع بازدید</span></div>
          </div>

          <div class="admin-grid">
            <section class="panel">
              <div class="panel-head">
                <h2>مدیریت پست‌ها</h2>
                <div class="actions">
                  <button class="btn btn-gold" id="newPostBtn" type="button">پست جدید</button>
                  <button class="btn btn-line" id="refreshBtn" type="button">بروزرسانی</button>
                </div>
              </div>

              <div class="panel-body">
                <div class="filters">
                  <input class="input" id="searchInput" type="search" placeholder="جستجو در پست‌ها..." />

                  <select class="select" id="statusFilter">
                    <option value="all">همه وضعیت‌ها</option>
                    <option value="published">منتشر شده</option>
                    <option value="draft">منتشر نشده</option>
                  </select>

                  <select class="select" id="mediaFilter">
                    <option value="all">همه محتواها</option>
                    <option value="media">دارای فایل</option>
                    <option value="photo">عکس</option>
                    <option value="video">ویدیو</option>
                    <option value="audio">صوت</option>
                    <option value="text">بدون فایل</option>
                  </select>

                  <select class="select" id="sortFilter">
                    <option value="newest">جدیدترین</option>
                    <option value="oldest">قدیمی‌ترین</option>
                    <option value="views">پربازدیدترین</option>
                  </select>
                </div>

                <div class="bulkbar">
                  <strong id="selectedCount">۰ پست انتخاب شده</strong>

                  <div class="actions">
                    <button class="btn btn-line" id="selectAllBtn" type="button">انتخاب همه</button>
                    <button class="btn btn-green" id="bulkPublishBtn" type="button">انتشار</button>
                    <button class="btn btn-gold" id="bulkUnpublishBtn" type="button">عدم انتشار</button>
                    <button class="btn btn-danger" id="bulkDeleteBtn" type="button">حذف</button>
                  </div>
                </div>

                <div class="posts-list" id="postsList">
                  <div class="empty">در حال دریافت پست‌ها...</div>
                </div>
              </div>
            </section>

            <aside class="panel">
              <div class="panel-head">
                <h2 id="editorTitle">ویرایش پست</h2>
              </div>

              <div class="panel-body">
                <div class="message" id="editorMessage"></div>

                <input type="hidden" id="postId" />

                <div class="editor-meta">
                  <div class="mini-stat"><strong id="charCount">0</strong><span>کاراکتر</span></div>
                  <div class="mini-stat"><strong id="wordCount">0</strong><span>کلمه</span></div>
                  <div class="mini-stat"><strong id="tagCount">0</strong><span>هشتگ</span></div>
                  <div class="mini-stat"><strong id="viewCount">0</strong><span>بازدید</span></div>
                </div>

                <div class="field">
                  <label for="postSlug">Slug / آدرس پست</label>
                  <div style="display:grid; grid-template-columns: 1fr auto; gap: 8px;">
                    <input class="input" id="postSlug" type="text" placeholder="post-slug" />
                    <button class="btn btn-line" id="generateSlugBtn" type="button">ساخت</button>
                  </div>
                </div>

                <div class="switch-line">
                  <span>انتشار در سایت</span>
                  <input id="isPublished" type="checkbox" checked />
                </div>

                <h3 class="tab-title">فایل پست</h3>

                <div class="media-uploader">
                  <div class="media-uploader-row">
                    <input
                      class="input"
                      id="mediaFile"
                      type="file"
                      accept="image/*,video/*,audio/*,.pdf,.doc,.docx,.xls,.xlsx,.ppt,.pptx,.zip,.rar"
                    />
                    <button class="btn btn-blue" id="uploadMediaBtn" type="button">آپلود فایل</button>
                    <button class="btn btn-danger" id="removeMediaBtn" type="button">حذف فایل</button>
                  </div>

                  <div class="media-preview" id="mediaPreview">
                    هنوز فایلی برای این پست انتخاب نشده است.
                  </div>
                </div>

                <div class="field">
                  <label for="postText">متن پست</label>
                  <textarea class="textarea" id="postText" placeholder="متن پست را وارد کن..."></textarea>
                </div>

                <h3 class="tab-title">تنظیمات SEO</h3>

                <div class="field">
                  <label for="seoTitle">SEO Title</label>
                  <input class="input" id="seoTitle" type="text" placeholder="اگر خالی باشد، عنوان از متن ساخته می‌شود" />
                </div>

                <div class="field">
                  <label for="seoDescription">SEO Description</label>
                  <textarea class="textarea small" id="seoDescription" placeholder="توضیح کوتاه برای گوگل و شبکه‌های اجتماعی"></textarea>
                </div>

                <h3 class="tab-title">یادداشت داخلی</h3>

                <div class="field">
                  <label for="adminNote">یادداشت فقط برای مدیر</label>
                  <textarea class="textarea small" id="adminNote" placeholder="مثلاً: نیاز به بازبینی، زمان انتشار، نکته داخلی..."></textarea>
                </div>

                <div class="editor-actions">
                  <button class="btn btn-primary" id="saveBtn" type="button">ذخیره</button>
                  <button class="btn btn-green" id="openPostBtn" type="button">مشاهده</button>
                  <button class="btn btn-blue" id="copyLinkBtn" type="button">کپی لینک</button>
                  <button class="btn btn-gold" id="duplicateBtn" type="button">کپی پست</button>
                  <button class="btn btn-danger" id="deleteBtn" type="button">حذف</button>
                  <button class="btn btn-line" id="clearBtn" type="button">پاک کردن</button>
                </div>

                <div class="preview">
                  <div class="preview-head">
                    <strong>پیش‌نمایش زنده</strong>
                    <span class="badge" id="previewStatus">پیش‌نویس</span>
                  </div>

                  <div class="preview-body">
                    <h3 class="preview-title" id="previewTitle">عنوان پست</h3>
                    <div class="preview-content" id="previewContent">متن پست اینجا نمایش داده می‌شود.</div>
                    <div class="preview-tags" id="previewTags"></div>
                  </div>
                </div>
              </div>
            </aside>
          </div>
        </section>
      </div>
    </main>

    <script define:vars={{ WORKER_URL }}>
      const TOKEN_KEY = "mahoon_admin_token";

      const loginView = document.getElementById("loginView");
      const dashboardView = document.getElementById("dashboardView");

      const tokenInput = document.getElementById("tokenInput");
      const loginBtn = document.getElementById("loginBtn");
      const logoutBtn = document.getElementById("logoutBtn");
      const loginMessage = document.getElementById("loginMessage");

      const postsList = document.getElementById("postsList");
      const searchInput = document.getElementById("searchInput");
      const statusFilter = document.getElementById("statusFilter");
      const mediaFilter = document.getElementById("mediaFilter");
      const sortFilter = document.getElementById("sortFilter");

      const refreshBtn = document.getElementById("refreshBtn");
      const newPostBtn = document.getElementById("newPostBtn");
      const exportBtn = document.getElementById("exportBtn");

      const selectedCount = document.getElementById("selectedCount");
      const selectAllBtn = document.getElementById("selectAllBtn");
      const bulkPublishBtn = document.getElementById("bulkPublishBtn");
      const bulkUnpublishBtn = document.getElementById("bulkUnpublishBtn");
      const bulkDeleteBtn = document.getElementById("bulkDeleteBtn");

      const totalCount = document.getElementById("totalCount");
      const publishedCount = document.getElementById("publishedCount");
      const draftCount = document.getElementById("draftCount");
      const mediaCount = document.getElementById("mediaCount");
      const viewsCount = document.getElementById("viewsCount");

      const editorTitle = document.getElementById("editorTitle");
      const editorMessage = document.getElementById("editorMessage");

      const postId = document.getElementById("postId");
      const postSlug = document.getElementById("postSlug");
      const isPublished = document.getElementById("isPublished");
      const postText = document.getElementById("postText");
      const seoTitle = document.getElementById("seoTitle");
      const seoDescription = document.getElementById("seoDescription");
      const adminNote = document.getElementById("adminNote");

      const mediaFile = document.getElementById("mediaFile");
      const uploadMediaBtn = document.getElementById("uploadMediaBtn");
      const removeMediaBtn = document.getElementById("removeMediaBtn");
      const mediaPreview = document.getElementById("mediaPreview");

      const charCount = document.getElementById("charCount");
      const wordCount = document.getElementById("wordCount");
      const tagCount = document.getElementById("tagCount");
      const viewCount = document.getElementById("viewCount");

      const saveBtn = document.getElementById("saveBtn");
      const deleteBtn = document.getElementById("deleteBtn");
      const openPostBtn = document.getElementById("openPostBtn");
      const copyLinkBtn = document.getElementById("copyLinkBtn");
      const duplicateBtn = document.getElementById("duplicateBtn");
      const clearBtn = document.getElementById("clearBtn");
      const generateSlugBtn = document.getElementById("generateSlugBtn");

      const previewStatus = document.getElementById("previewStatus");
      const previewTitle = document.getElementById("previewTitle");
      const previewContent = document.getElementById("previewContent");
      const previewTags = document.getElementById("previewTags");

      let posts = [];
      let selectedPost = null;
      let selectedIds = new Set();
      let currentMedia = null;

      function getToken() {
        return localStorage.getItem(TOKEN_KEY) || "";
      }

      function setToken(token) {
        localStorage.setItem(TOKEN_KEY, token);
      }

      function clearToken() {
        localStorage.removeItem(TOKEN_KEY);
      }

      function showLogin() {
        loginView.classList.add("active");
        dashboardView.classList.remove("active");
      }

      function showDashboard() {
        loginView.classList.remove("active");
        dashboardView.classList.add("active");
      }

      function showMessage(element, text, type = "ok") {
        element.textContent = text;
        element.className = `message show ${type}`;

        setTimeout(() => {
          element.className = "message";
        }, 3800);
      }

      function authHeaders() {
        return {
          "Content-Type": "application/json",
          "Authorization": `Bearer ${getToken()}`
        };
      }

      function authOnlyHeaders() {
        return {
          "Authorization": `Bearer ${getToken()}`
        };
      }

      async function api(path, options = {}) {
        const res = await fetch(`${WORKER_URL}${path}`, {
          ...options,
          headers: {
            ...authHeaders(),
            ...(options.headers || {})
          }
        });

        const data = await res.json().catch(() => null);

        if (!res.ok) {
          throw new Error(data?.error || "خطا در ارتباط با سرور");
        }

        return data;
      }

      function normalizeText(value) {
        return String(value || "")
          .replace(/\r\n/g, "\n")
          .replace(/\r/g, "\n")
          .trim();
      }

      function parseContent(text) {
        const original = normalizeText(text);
        const hashtags = Array.from(new Set((original.match(/#[\p{L}\p{N}_]+/gu) || []).map(tag => tag.replace("#", ""))));
        const urls = Array.from(new Set(original.match(/(https?:\/\/[^\s]+)/g) || []));
        const cleanLines = [];

        original.split("\n").forEach(rawLine => {
          const line = rawLine.trim();

          if (!line) {
            if (cleanLines.length && cleanLines[cleanLines.length - 1] !== "") cleanLines.push("");
            return;
          }

          const cleaned = line
            .replace(/(https?:\/\/[^\s]+)/g, "")
            .replace(/#[\p{L}\p{N}_]+/gu, "")
            .replace(/@[\w.]+/g, "")
            .replace(/[◆◇🔹🔸▪️•]+/g, "")
            .replace(/\s+/g, " ")
            .trim();

          if (cleaned) cleanLines.push(cleaned);
        });

        while (cleanLines[cleanLines.length - 1] === "") cleanLines.pop();

        const content = cleanLines.join("\n").trim();
        const title = (cleanLines.find(Boolean) || "پست بدون عنوان").slice(0, 90);
        const excerpt = content.replace(/\n/g, " ").replace(/\s+/g, " ").slice(0, 160);

        return { title, content, excerpt, hashtags, urls };
      }

      function makeSlugFromText(text) {
        const parsed = parseContent(text);
        const base = parsed.title
          .toLowerCase()
          .replace(/[^a-z0-9\u0600-\u06FF\s-]/g, "")
          .replace(/\s+/g, "-")
          .replace(/-+/g, "-")
          .replace(/^-|-$/g, "")
          .slice(0, 70);

        return `${base || "post"}-${Date.now()}`;
      }

      function makeTitle(text) {
        return parseContent(text).title || "پست بدون عنوان";
      }

      function makeExcerpt(text) {
        return parseContent(text).excerpt || "";
      }

      function formatDate(value) {
        if (!value) return "";

        try {
          const date = new Date(value.replace(" ", "T") + "Z");

          return new Intl.DateTimeFormat("fa-IR", {
            year: "numeric",
            month: "short",
            day: "numeric",
            hour: "2-digit",
            minute: "2-digit"
          }).format(date);
        } catch {
          return value;
        }
      }

      function escapeHtml(value) {
        return String(value || "")
          .replaceAll("&", "&amp;")
          .replaceAll("<", "&lt;")
          .replaceAll(">", "&gt;")
          .replaceAll('"', "&quot;")
          .replaceAll("'", "&#039;");
      }

      function escapeAttr(value) {
        return escapeHtml(value).replaceAll("`", "&#096;");
      }

      function mediaLabel(type) {
        if (type === "photo") return "عکس";
        if (type === "video") return "ویدیو";
        if (type === "audio") return "صوت";
        if (type === "voice") return "ویس";
        if (type === "document") return "فایل";
        return "فایل";
      }

      function mediaFromPost(post) {
        if (!post) return null;

        const fileId = post.media_file_id || post.photo_file_id || null;
        const mediaType = post.media_type || (post.photo_file_id ? "photo" : null);

        if (!fileId || !mediaType) return null;

        return {
          media_type: mediaType,
          media_file_id: fileId,
          media_unique_id: post.media_unique_id || post.photo_unique_id || null,
          media_mime_type: post.media_mime_type || null,
          media_file_name: post.media_file_name || null,
          media_duration: post.media_duration || null,
          media_width: post.media_width || post.photo_width || null,
          media_height: post.media_height || post.photo_height || null,
          media_size: post.media_size || null,
          media_url: post.media_url || post.photo_url || null,
          photo_url: mediaType === "photo" ? post.media_url || post.photo_url : null
        };
      }

      function renderMediaPreview() {
        if (!currentMedia || !currentMedia.media_file_id) {
          mediaPreview.innerHTML = "هنوز فایلی برای این پست انتخاب نشده است.";
          return;
        }

        const url = currentMedia.media_url;
        const type = currentMedia.media_type;

        if (type === "photo" && url) {
          mediaPreview.innerHTML = `<img src="${escapeAttr(url)}" alt="">`;
          return;
        }

        if (type === "video" && url) {
          mediaPreview.innerHTML = `<video src="${escapeAttr(url)}" controls playsinline preload="metadata"></video>`;
          return;
        }

        if ((type === "audio" || type === "voice") && url) {
          mediaPreview.innerHTML = `
            <div class="file-preview">
              <strong>${mediaLabel(type)}</strong>
              <audio src="${escapeAttr(url)}" controls preload="metadata"></audio>
            </div>
          `;
          return;
        }

        if (url) {
          mediaPreview.innerHTML = `
            <div class="file-preview">
              <strong>${escapeHtml(currentMedia.media_file_name || "فایل پیوست")}</strong>
              <span>${escapeHtml(currentMedia.media_mime_type || mediaLabel(type))}</span>
              <a class="btn btn-primary" href="${escapeAttr(url)}" target="_blank" rel="noopener">مشاهده فایل</a>
            </div>
          `;
          return;
        }

        mediaPreview.innerHTML = `${mediaLabel(type)} انتخاب شده است.`;
      }

      async function testLogin() {
        try {
          await api("/admin/health");
          showDashboard();
          await loadPosts();
        } catch {
          clearToken();
          showLogin();
          showMessage(loginMessage, "رمز مدیریت اشتباه است یا Worker تنظیم نشده.", "error");
        }
      }

      async function loadPosts() {
        postsList.innerHTML = `<div class="empty">در حال دریافت پست‌ها...</div>`;

        try {
          const data = await api("/admin/posts");
          posts = data.posts || [];
          selectedIds = new Set();

          renderStats();
          renderPosts();
          updateSelectedCount();
        } catch (error) {
          postsList.innerHTML = `<div class="empty">${escapeHtml(error.message)}</div>`;
        }
      }

      function renderStats() {
        const published = posts.filter(post => Number(post.is_published) === 1).length;
        const drafts = posts.filter(post => Number(post.is_published) !== 1).length;
        const withMedia = posts.filter(post => post.media_file_id || post.photo_file_id).length;
        const totalViews = posts.reduce((sum, post) => sum + Number(post.view_count || 0), 0);

        totalCount.textContent = posts.length;
        publishedCount.textContent = published;
        draftCount.textContent = drafts;
        mediaCount.textContent = withMedia;
        viewsCount.textContent = totalViews;
      }

      function getFilteredPosts() {
        const query = (searchInput.value || "").trim().toLowerCase();
        const status = statusFilter.value;
        const media = mediaFilter.value;
        const sort = sortFilter.value;

        let filtered = posts.filter(post => {
          const parsed = parseContent(post.text);
          const mediaType = post.media_type || (post.photo_file_id ? "photo" : null);
          const hasMedia = Boolean(post.media_file_id || post.photo_file_id);

          const searchText = `${post.id} ${post.slug} ${post.text} ${post.seo_title || ""} ${post.seo_description || ""} ${parsed.hashtags.join(" ")}`.toLowerCase();

          const matchesQuery = !query || searchText.includes(query);
          const matchesStatus =
            status === "all" ||
            (status === "published" && Number(post.is_published) === 1) ||
            (status === "draft" && Number(post.is_published) !== 1);

          const matchesMedia =
            media === "all" ||
            (media === "media" && hasMedia) ||
            (media === "photo" && mediaType === "photo") ||
            (media === "video" && mediaType === "video") ||
            (media === "audio" && (mediaType === "audio" || mediaType === "voice")) ||
            (media === "text" && !hasMedia);

          return matchesQuery && matchesStatus && matchesMedia;
        });

        if (sort === "oldest") {
          filtered.sort((a, b) => Number(a.id) - Number(b.id));
        } else if (sort === "views") {
          filtered.sort((a, b) => Number(b.view_count || 0) - Number(a.view_count || 0));
        } else {
          filtered.sort((a, b) => Number(b.id) - Number(a.id));
        }

        return filtered;
      }

      function renderThumb(post) {
        const media = mediaFromPost(post);

        if (!media) return `<span>بدون فایل</span>`;

        if (media.media_type === "photo" && media.media_url) {
          return `<img src="${escapeAttr(media.media_url)}" alt="">`;
        }

        if (media.media_type === "video" && media.media_url) {
          return `<video src="${escapeAttr(media.media_url)}" muted preload="metadata"></video>`;
        }

        return `<span>${mediaLabel(media.media_type)}</span>`;
      }

      function renderPosts() {
        const filtered = getFilteredPosts();

        if (filtered.length === 0) {
          postsList.innerHTML = `<div class="empty">پستی پیدا نشد.</div>`;
          return;
        }

        postsList.innerHTML = filtered.map(post => {
          const active = selectedPost && Number(selectedPost.id) === Number(post.id) ? "active" : "";
          const checked = selectedIds.has(Number(post.id)) ? "checked" : "";
          const statusClass = Number(post.is_published) === 1 ? "green" : "red";
          const statusText = Number(post.is_published) === 1 ? "منتشر شده" : "منتشر نشده";
          const title = makeTitle(post.text);
          const excerpt = makeExcerpt(post.text);
          const media = mediaFromPost(post);

          return `
            <article class="post-row ${active}" data-row-id="${post.id}">
              <div class="post-check">
                <input type="checkbox" data-check-id="${post.id}" ${checked} />
              </div>

              <div class="thumb">
                ${renderThumb(post)}
              </div>

              <div>
                <h3>${escapeHtml(title)}</h3>
                <p>${escapeHtml(excerpt)}</p>

                <div class="row-meta">
                  <span class="badge gray">#${post.id}</span>
                  <span class="badge ${statusClass}">${statusText}</span>
                  ${media ? `<span class="badge">${mediaLabel(media.media_type)}</span>` : ""}
                  <span class="badge blue">${Number(post.view_count || 0)} بازدید</span>
                  <span class="badge gray">${escapeHtml(formatDate(post.created_at))}</span>
                </div>
              </div>
            </article>
          `;
        }).join("");
      }

      function updateSelectedCount() {
        selectedCount.textContent = `${selectedIds.size} پست انتخاب شده`;
      }

      function selectPost(post) {
        selectedPost = post;
        currentMedia = mediaFromPost(post);

        editorTitle.textContent = `ویرایش پست #${post.id}`;
        postId.value = post.id;
        postSlug.value = post.slug || "";
        isPublished.checked = Number(post.is_published) === 1;
        postText.value = post.text || "";
        seoTitle.value = post.seo_title || "";
        seoDescription.value = post.seo_description || "";
        adminNote.value = post.admin_note || "";
        viewCount.textContent = Number(post.view_count || 0);

        renderMediaPreview();
        updateEditorStats();
        updatePreview();
        renderPosts();
      }

      function clearEditor() {
        selectedPost = null;
        currentMedia = null;

        editorTitle.textContent = "ساخت پست جدید";
        postId.value = "";
        postSlug.value = "";
        isPublished.checked = true;
        postText.value = "";
        seoTitle.value = "";
        seoDescription.value = "";
        adminNote.value = "";
        viewCount.textContent = "0";
        mediaFile.value = "";

        renderMediaPreview();
        updateEditorStats();
        updatePreview();
        renderPosts();
      }

      function updateEditorStats() {
        const text = postText.value || "";
        const parsed = parseContent(text);
        const words = text.trim() ? text.trim().split(/\s+/).length : 0;

        charCount.textContent = text.length;
        wordCount.textContent = words;
        tagCount.textContent = parsed.hashtags.length;
      }

      function updatePreview() {
        const parsed = parseContent(postText.value || "");

        previewTitle.textContent = parsed.title || "عنوان پست";
        previewContent.textContent = parsed.content || "متن پست اینجا نمایش داده می‌شود.";
        previewStatus.textContent = isPublished.checked ? "منتشر شده" : "منتشر نشده";
        previewStatus.className = isPublished.checked ? "badge green" : "badge red";

        previewTags.innerHTML = parsed.hashtags.length
          ? parsed.hashtags.map(tag => `<span class="badge">#${escapeHtml(tag)}</span>`).join("")
          : `<span class="badge gray">بدون هشتگ</span>`;
      }

      function editorPayload() {
        const media = currentMedia || {};

        return {
          text: postText.value.trim(),
          slug: postSlug.value.trim(),
          is_published: isPublished.checked ? 1 : 0,
          seo_title: seoTitle.value.trim(),
          seo_description: seoDescription.value.trim(),
          admin_note: adminNote.value.trim(),

          media_type: media.media_type || null,
          media_file_id: media.media_file_id || null,
          media_unique_id: media.media_unique_id || null,
          media_mime_type: media.media_mime_type || null,
          media_file_name: media.media_file_name || null,
          media_duration: media.media_duration || null,
          media_width: media.media_width || null,
          media_height: media.media_height || null,
          media_size: media.media_size || null
        };
      }

      async function uploadMedia() {
        const file = mediaFile.files && mediaFile.files[0];

        if (!file) {
          showMessage(editorMessage, "اول یک فایل انتخاب کن.", "error");
          return;
        }

        const formData = new FormData();
        formData.append("file", file);

        uploadMediaBtn.disabled = true;
        uploadMediaBtn.textContent = "در حال آپلود...";

        try {
          const res = await fetch(`${WORKER_URL}/admin/upload`, {
            method: "POST",
            headers: authOnlyHeaders(),
            body: formData
          });

          const data = await res.json().catch(() => null);

          if (!res.ok || !data?.ok) {
            throw new Error(data?.error || "آپلود فایل ناموفق بود.");
          }

          currentMedia = data.media;
          renderMediaPreview();
          showMessage(editorMessage, "فایل با موفقیت در تلگرام ذخیره شد.", "ok");
        } catch (error) {
          showMessage(editorMessage, error.message, "error");
        } finally {
          uploadMediaBtn.disabled = false;
          uploadMediaBtn.textContent = "آپلود فایل";
        }
      }

      function removeMedia() {
        currentMedia = null;
        mediaFile.value = "";
        renderMediaPreview();
        showMessage(editorMessage, "فایل از این پست حذف شد. برای اعمال تغییر، ذخیره را بزن.", "ok");
      }

      async function savePost() {
        const id = postId.value;
        const payload = editorPayload();

        if (!payload.text) {
          showMessage(editorMessage, "متن پست نمی‌تواند خالی باشد.", "error");
          return;
        }

        try {
          if (id) {
            await api(`/admin/posts/${id}`, {
              method: "PATCH",
              body: JSON.stringify(payload)
            });

            showMessage(editorMessage, "پست با موفقیت ذخیره شد.", "ok");
          } else {
            const data = await api("/admin/posts", {
              method: "POST",
              body: JSON.stringify(payload)
            });

            showMessage(editorMessage, "پست جدید ساخته شد.", "ok");

            postId.value = data.id || "";
            postSlug.value = data.slug || payload.slug;
          }

          await loadPosts();

          const fresh = posts.find(item => Number(item.id) === Number(postId.value));

          if (fresh) {
            selectPost(fresh);
          }
        } catch (error) {
          showMessage(editorMessage, error.message, "error");
        }
      }

      async function deletePost() {
        const id = postId.value;

        if (!id) {
          showMessage(editorMessage, "برای حذف، اول یک پست را انتخاب کن.", "error");
          return;
        }

        const confirmed = confirm("این پست از سایت حذف شود؟ حذف به صورت نرم انجام می‌شود.");

        if (!confirmed) return;

        try {
          await api(`/admin/posts/${id}`, {
            method: "DELETE"
          });

          showMessage(editorMessage, "پست حذف شد.", "ok");
          clearEditor();
          await loadPosts();
        } catch (error) {
          showMessage(editorMessage, error.message, "error");
        }
      }

      async function duplicatePost() {
        const payload = editorPayload();

        if (!payload.text) {
          showMessage(editorMessage, "متن پست خالی است.", "error");
          return;
        }

        payload.slug = "";
        payload.is_published = 0;
        payload.admin_note = payload.admin_note ? payload.admin_note + "\nکپی شده از پست قبلی" : "کپی شده از پست قبلی";

        try {
          const data = await api("/admin/posts", {
            method: "POST",
            body: JSON.stringify(payload)
          });

          showMessage(editorMessage, "کپی پست ساخته شد و در حالت منتشر نشده قرار گرفت.", "ok");

          await loadPosts();

          const fresh = posts.find(item => Number(item.id) === Number(data.id));

          if (fresh) {
            selectPost(fresh);
          }
        } catch (error) {
          showMessage(editorMessage, error.message, "error");
        }
      }

      async function bulkAction(action) {
        if (selectedIds.size === 0) {
          alert("هیچ پستی انتخاب نشده است.");
          return;
        }

        if (action === "delete") {
          const confirmed = confirm("پست‌های انتخاب‌شده حذف شوند؟");
          if (!confirmed) return;
        }

        try {
          await api("/admin/posts/bulk", {
            method: "POST",
            body: JSON.stringify({
              action,
              ids: Array.from(selectedIds)
            })
          });

          selectedIds = new Set();
          await loadPosts();
        } catch (error) {
          alert(error.message);
        }
      }

      function openPost() {
        const slug = postSlug.value.trim();

        if (!slug) {
          showMessage(editorMessage, "این پست slug ندارد.", "error");
          return;
        }

        window.open(`/post/${encodeURIComponent(slug)}`, "_blank");
      }

      async function copyLink() {
        const slug = postSlug.value.trim();

        if (!slug) {
          showMessage(editorMessage, "این پست slug ندارد.", "error");
          return;
        }

        const link = `${window.location.origin}/post/${encodeURIComponent(slug)}`;

        try {
          await navigator.clipboard.writeText(link);
          showMessage(editorMessage, "لینک پست کپی شد.", "ok");
        } catch {
          showMessage(editorMessage, link, "ok");
        }
      }

      function exportJson() {
        const data = JSON.stringify(posts, null, 2);
        const blob = new Blob([data], { type: "application/json;charset=utf-8" });
        const url = URL.createObjectURL(blob);

        const a = document.createElement("a");
        a.href = url;
        a.download = `mahoon-posts-${Date.now()}.json`;
        a.click();

        URL.revokeObjectURL(url);
      }

      postsList.addEventListener("click", event => {
        const checkbox = event.target.closest("[data-check-id]");

        if (checkbox) {
          const id = Number(checkbox.getAttribute("data-check-id"));

          if (checkbox.checked) {
            selectedIds.add(id);
          } else {
            selectedIds.delete(id);
          }

          updateSelectedCount();
          return;
        }

        const row = event.target.closest("[data-row-id]");
        if (!row) return;

        const id = Number(row.getAttribute("data-row-id"));
        const post = posts.find(item => Number(item.id) === id);

        if (post) {
          selectPost(post);
        }
      });

      loginBtn.addEventListener("click", async () => {
        const token = tokenInput.value.trim();

        if (!token) {
          showMessage(loginMessage, "رمز مدیریت را وارد کن.", "error");
          return;
        }

        setToken(token);
        await testLogin();
      });

      tokenInput.addEventListener("keydown", event => {
        if (event.key === "Enter") {
          loginBtn.click();
        }
      });

      logoutBtn.addEventListener("click", () => {
        clearToken();
        showLogin();
      });

      refreshBtn.addEventListener("click", loadPosts);
      searchInput.addEventListener("input", renderPosts);
      statusFilter.addEventListener("change", renderPosts);
      mediaFilter.addEventListener("change", renderPosts);
      sortFilter.addEventListener("change", renderPosts);

      newPostBtn.addEventListener("click", clearEditor);
      clearBtn.addEventListener("click", clearEditor);
      saveBtn.addEventListener("click", savePost);
      deleteBtn.addEventListener("click", deletePost);
      duplicateBtn.addEventListener("click", duplicatePost);
      openPostBtn.addEventListener("click", openPost);
      copyLinkBtn.addEventListener("click", copyLink);
      exportBtn.addEventListener("click", exportJson);

      uploadMediaBtn.addEventListener("click", uploadMedia);
      removeMediaBtn.addEventListener("click", removeMedia);

      bulkPublishBtn.addEventListener("click", () => bulkAction("publish"));
      bulkUnpublishBtn.addEventListener("click", () => bulkAction("unpublish"));
      bulkDeleteBtn.addEventListener("click", () => bulkAction("delete"));

      selectAllBtn.addEventListener("click", () => {
        const filtered = getFilteredPosts();

        if (selectedIds.size === filtered.length) {
          selectedIds = new Set();
        } else {
          selectedIds = new Set(filtered.map(post => Number(post.id)));
        }

        updateSelectedCount();
        renderPosts();
      });

      generateSlugBtn.addEventListener("click", () => {
        postSlug.value = makeSlugFromText(postText.value);
      });

      postText.addEventListener("input", () => {
        updateEditorStats();
        updatePreview();
      });

      isPublished.addEventListener("change", updatePreview);
      seoTitle.addEventListener("input", updatePreview);
      seoDescription.addEventListener("input", updatePreview);

      clearEditor();

      if (getToken()) {
        testLogin();
      } else {
        showLogin();
      }
    </script>
  </body>
</html>