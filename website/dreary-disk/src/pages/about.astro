---
import BaseLayout from "../layouts/BaseLayout.astro";
import { SITE } from "../config";
---

<BaseLayout title="درباره ماهون" description="درباره مجله هنری ماهون">
  <main class="page-section">
    <div class="container">
      <section class="page-card">
        <span class="tag">درباره ماهون</span>

        <h1>مجله هنری ماهون</h1>

        <p>
          ماهون رسانه‌ای برای روایت هنر، فرهنگ و نگاه معاصر است؛ جایی برای ثبت و انتشار نوشته‌ها،
          یادداشت‌ها، خبرها و روایت‌هایی که از دل جهان هنر و فرهنگ می‌آیند.
        </p>

        <p>
          این نسخه از سایت به صورت خودکار به کانال تلگرام متصل شده است. هر مطلبی که در کانال منتشر شود،
          پس از دریافت توسط سیستم، به یک صفحه مستقل در وب‌سایت تبدیل می‌شود تا امکان جستجو، اشتراک‌گذاری
          و دیده‌شدن در فضای وب فراهم شود.
        </p>

        <p>
          هدف این نسخه اولیه، ساخت یک پایگاه آنلاین سبک، سریع و قابل توسعه برای محتوای ماهون است.
        </p>
      </section>
    </div>
  </main>
</BaseLayout>